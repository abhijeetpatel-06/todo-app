<%- include("partials/header") %>

<h2 class="page-title">📋 All Tasks</h2>

<div class="todo-grid">
    <% todos.forEach(todo => { %>
        <div class="todo-card">
            <div class="card-header">
                <h3><%= todo.title %></h3>
                <span class="date">
                    <%= moment(todo.createdAt).format("DD MMM YYYY, hh:mm A") %>
                </span>
            </div>

            <p class="desc"><%= todo.desc || "No description" %></p>

            <div class="card-buttons">
                <a href="/update-todo?id=<%= todo._id %>" class="btn edit">Edit</a>
                <a href="/delete-todo?id=<%= todo._id %>" class="btn delete">Delete</a>
            </div>
        </div>
    <% }) %>
</div>

<%- include("partials/footer") %>